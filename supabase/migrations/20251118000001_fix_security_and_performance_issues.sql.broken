  USING (
    EXISTS (
      SELECT 1 FROM user_roles
      WHERE user_id = (SELECT auth.uid())
      AND role IN ('super_admin', 'admin')
    )
  );

-- feature_use_cases table
DROP POLICY IF EXISTS "Admins can manage use cases" ON feature_use_cases;
CREATE POLICY "Admins can manage use cases" ON feature_use_cases
  FOR ALL TO authenticated
  USING (
    EXISTS (
      SELECT 1 FROM user_roles
      WHERE user_id = (SELECT auth.uid())
      AND role IN ('super_admin', 'admin')
    )
  );

-- feature_faqs table
DROP POLICY IF EXISTS "Admins can manage FAQs" ON feature_faqs;
CREATE POLICY "Admins can manage FAQs" ON feature_faqs
  FOR ALL TO authenticated
  USING (
    EXISTS (
      SELECT 1 FROM user_roles
      WHERE user_id = (SELECT auth.uid())
      AND role IN ('super_admin', 'admin')
    )
