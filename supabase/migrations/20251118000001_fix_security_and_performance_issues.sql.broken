DROP INDEX IF EXISTS idx_feature_analytics_feature_id;
DROP INDEX IF EXISTS idx_user_feature_interactions_user_id;
DROP INDEX IF EXISTS idx_user_feature_interactions_feature_id;
DROP INDEX IF EXISTS idx_feature_ratings_feature_id;
DROP INDEX IF EXISTS idx_feature_relationships_feature_id;
DROP INDEX IF EXISTS idx_import_products_first_seen_in_import_id;
DROP INDEX IF EXISTS idx_import_user_records_import_product_id;
DROP INDEX IF EXISTS idx_platform_product_mappings_product_id;
DROP INDEX IF EXISTS idx_product_app_mappings_verified_by;
DROP INDEX IF EXISTS idx_stripe_entitlements_user_id;
DROP INDEX IF EXISTS idx_subscription_status_user_id;
DROP INDEX IF EXISTS idx_videos_user_id;

-- ============================================================================
-- PART 4: CONSOLIDATE MULTIPLE PERMISSIVE POLICIES
-- ============================================================================

-- access_tiers table
DROP POLICY IF EXISTS "Admins can manage access tiers" ON access_tiers;
DROP POLICY IF EXISTS "Users can view active tiers" ON access_tiers;

CREATE POLICY "View access tiers" ON access_tiers
  FOR SELECT TO authenticated
  USING (
    is_active = true OR
    EXISTS (
      SELECT 1 FROM user_roles
      WHERE user_id = (SELECT auth.uid())
      AND role IN ('super_admin', 'admin')
    )
  );

CREATE POLICY "Admins manage tiers" ON access_tiers
  FOR ALL TO authenticated
  USING (
    EXISTS (
      SELECT 1 FROM user_roles
      WHERE user_id = (SELECT auth.uid())
      AND role IN ('super_admin', 'admin')
    )
  )
  WITH CHECK (
    EXISTS (
      SELECT 1 FROM user_roles
      WHERE user_id = (SELECT auth.uid())
      AND role IN ('super_admin', 'admin')
    )
  );

-- app_features table (already handled above, ensure view policy exists)
DROP POLICY IF EXISTS "Anyone can view features" ON app_features;
CREATE POLICY "Anyone can view features" ON app_features
  FOR SELECT TO authenticated
  USING (true);

-- apps table
DROP POLICY IF EXISTS "Admins manage apps" ON apps;
DROP POLICY IF EXISTS "Users can view apps" ON apps;

CREATE POLICY "View apps" ON apps
  FOR SELECT TO authenticated
  USING (
    EXISTS (
      SELECT 1 FROM user_roles
      WHERE user_id = (SELECT auth.uid())
      AND role IN ('super_admin', 'admin')
    ) OR true
  );

CREATE POLICY "Admins manage apps" ON apps
  FOR ALL TO authenticated
  USING (
    EXISTS (
      SELECT 1 FROM user_roles
      WHERE user_id = (SELECT auth.uid())
      AND role IN ('super_admin', 'admin')
    )
  )
  WITH CHECK (
    EXISTS (
      SELECT 1 FROM user_roles
      WHERE user_id = (SELECT auth.uid())
      AND role IN ('super_admin', 'admin')
    )
  );

-- Continue consolidating other tables...
