-- ============================================================================
-- PART 5: FIX FUNCTION SEARCH PATHS
-- ============================================================================

-- Set secure search_path for all functions
ALTER FUNCTION update_app_feature_count() SET search_path = public, pg_temp;
ALTER FUNCTION update_app_included_features() SET search_path = public, pg_temp;
ALTER FUNCTION user_has_feature_access(uuid, uuid) SET search_path = public, pg_temp;
ALTER FUNCTION update_feature_analytics() SET search_path = public, pg_temp;
ALTER FUNCTION get_feature_popularity(uuid) SET search_path = public, pg_temp;
ALTER FUNCTION get_recommended_features(uuid, integer) SET search_path = public, pg_temp;

-- ============================================================================
-- PART 6: FIX SECURITY DEFINER VIEW
-- ============================================================================

-- Drop and recreate view without SECURITY DEFINER
DROP VIEW IF EXISTS apps_with_features;

CREATE VIEW apps_with_features AS
SELECT
  a.id,
  a.name,
  a.slug,
  a.description,
  a.category,
  a.item_type,
  a.is_suite,
  a.feature_count,
  a.included_feature_ids,
  a.sort_order,
  COALESCE(
    (
      SELECT json_agg(
        json_build_object(
          'id', f.id,
          'name', f.name,
          'slug', f.slug,
          'description', f.description
        ) ORDER BY afl.sort_order
      )
      FROM app_feature_links afl
      JOIN apps f ON f.id = afl.feature_id
      WHERE afl.app_id = a.id
    ),
    '[]'::json
  ) as features
FROM apps a
WHERE a.is_active = true;

-- Grant appropriate access
GRANT SELECT ON apps_with_features TO authenticated;

-- ============================================================================
-- VERIFICATION
-- ============================================================================

DO $$
DECLARE
  index_count INTEGER;
  policy_count INTEGER;
BEGIN
  -- Count new indexes
  SELECT COUNT(*) INTO index_count
  FROM pg_indexes
  WHERE schemaname = 'public'
  AND indexname LIKE 'idx_%_fkey%' OR indexname IN (
    'idx_csv_imports_imported_by',
    'idx_feature_relationships_related_feature_id',
    'idx_import_user_records_csv_import_id',
    'idx_import_user_records_user_id',
    'idx_product_app_mappings_access_tier_id',
    'idx_product_app_mappings_app_id',
    'idx_purchases_product_id',
    'idx_subscription_status_purchase_id',
    'idx_sync_jobs_started_by',
    'idx_user_app_access_purchase_id'
  );

  RAISE NOTICE 'Migration Complete:';
  RAISE NOTICE '  Foreign key indexes added: %', index_count;
  RAISE NOTICE '  RLS policies optimized';
  RAISE NOTICE '  Unused indexes removed';
  RAISE NOTICE '  Permissive policies consolidated';
  RAISE NOTICE '  Function search paths secured';
  RAISE NOTICE '  Security definer view fixed';
END $$;
