DROP POLICY IF EXISTS "Anyone can view analytics" ON feature_analytics;
DROP POLICY IF EXISTS "System can update analytics" ON feature_analytics;

CREATE POLICY "View analytics" ON feature_analytics
  FOR SELECT TO authenticated
  USING (true);

CREATE POLICY "System updates analytics" ON feature_analytics
  FOR ALL TO authenticated
  USING (
    EXISTS (
      SELECT 1 FROM user_roles
      WHERE user_id = (SELECT auth.uid())
      AND role IN ('super_admin', 'admin')
    )
  );

