# ===========================================
# VideoRemix.vip - AI Creative Personalizer
# Environment Configuration
# Copy to .env.local (frontend) or set in Netlify/Render
# ===========================================

# ----- SUPABASE -----
# Your Supabase project URL
VITE_SUPABASE_URL=https://bzxohkrxcwodllketcpz.supabase.co
SUPABASE_URL=https://bzxohkrxcwodllketcpz.supabase.co

# Supabase anon key (public, for frontend)
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImJ6eG9oa3J4Y3dvZGxsa2V0Y3B6Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3Mzg2NjYzODUsImV4cCI6MjA1NDI0MjM4NX0.ExeLy2sWZMnLY4VToGlbqr3F4SpNmrsE9Hw0lyAhb9A

# Supabase service role key (PRIVATE, server-only, for admin operations)
# WARNING: Never expose this in the frontend or commit to git
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ----- AI API KEYS -----
# OpenAI API key (for GPT-4 content generation)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your_openai_key_here

# Google Gemini API key (fallback AI provider)
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_key_here

# ----- MAIGRET WORKER -----
# URL of your deployed Maigret worker on Render
MAIGRET_WORKER_URL=https://maigret-worker.onrender.com

# Secret key for Maigret worker authentication
# Generate a strong secret: openssl rand -hex 32
MAIGRET_WORKER_SECRET=your-32-char-hex-secret-here

# ----- GITHUB TOKEN -----
# Optional: GitHub personal access token for higher API rate limits
# Format: ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Scope needed: public_repo (or higher if scanning private profiles)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ----- CORS & SECURITY -----
# Comma-separated list of allowed origins for CORS
# For production, set to your actual domain(s)
ALLOWED_ORIGINS=https://videoremix.vip,https://www.videoremix.vip

# ----- RENDER (Maigret Worker) -----
# These go in your Render.com dashboard, not in this file
# PORT=8000 (set by Render automatically)
# PYTHON_VERSION=3.11.0
# Build Command: pip install -r requirements.txt
# Start Command: uvicorn main:app --host 0.0.0.0 --port $PORT

# ----- NETLIFY -----
# These go in your Netlify dashboard (Site settings > Environment variables)
# No additional variables needed beyond those listed above

# ----- OPTIONAL SETTINGS -----
# Override default rate limits (requests per minute per user)
# RATE_LIMIT_REQUESTS=20

# Maigret scan timeout in seconds
# MAIGRET_SCAN_TIMEOUT=60

# AI generation timeout in seconds
# AI_GENERATION_TIMEOUT=30

# ----- SITE URL -----
VITE_SITE_URL=http://localhost:5173

# ----- STRIPE -----
# Get publishable key from: https://dashboard.stripe.com/apikeys
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_your_key_here
# Get secret key from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_your_secret_key_here
# Get webhook secret from: https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# ----- PAYPAL -----
PAYPAL_WEBHOOK_ID=2PJ04027LS072544L
