# ----- GITHUB TOKEN -----
# Optional: GitHub personal access token for higher API rate limits
# Format: ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Scope needed: public_repo (or higher if scanning private profiles)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ----- CORS & SECURITY -----
# Comma-separated list of allowed origins for CORS
# For production, set to your actual domain(s)
ALLOWED_ORIGINS=https://videoremix.vip,https://www.videoremix.vip

# ----- RENDER (Maigret Worker) -----
# These go in your Render.com dashboard, not in this file
# PORT=8000 (set by Render automatically)
# PYTHON_VERSION=3.11.0
# Build Command: pip install -r requirements.txt
# Start Command: uvicorn main:app --host 0.0.0.0 --port $PORT

# ----- NETLIFY -----
# These go in your Netlify dashboard (Site settings > Environment variables)
# No additional variables needed beyond those listed above

# ----- OPTIONAL SETTINGS -----
# Override default rate limits (requests per minute per user)
# RATE_LIMIT_REQUESTS=20

