# 🎯 REVOLUTIONARY LAUNCH: Feature Flags Configuration

# Feature Flag Management for Card Tile & Modal Experience
# This file controls the rollout of revolutionary features

# Main feature flag
VITE_ENABLE_CARD_MODAL_EXPERIENCE=true

# Component-specific flags
VITE_ENABLE_ENHANCED_CARDS=true
VITE_ENABLE_DYNAMIC_SALES_COPY=true
VITE_ENABLE_CATEGORY_THEMING=true
VITE_ENABLE_ANIMATED_TRANSITIONS=true

# Analytics and tracking
VITE_ENABLE_LAUNCH_ANALYTICS=true
VITE_ENABLE_USER_FEEDBACK=true

# Performance monitoring
VITE_ENABLE_PERFORMANCE_MONITORING=true
VITE_ENABLE_ERROR_TRACKING=true

# Rollout configuration
VITE_FEATURE_ROLLOUT_PERCENTAGE=100
VITE_BETA_USER_LIST=beta-users.json

# Emergency controls
VITE_ENABLE_EMERGENCY_ROLLBACK=false
VITE_ROLLBACK_VERSION=v1.0.0-stable