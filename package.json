{
  "name": "videoremix",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "test": "vitest",
    "validate-env": "node validate-env.mjs",
    "prebuild": "npm run validate-env",
    "predev": "npm run validate-env",
    "deploy": "bash scripts/deploy.sh",
    "deploy:netlify": "npm run build && netlify deploy --prod --dir=dist",
    "monitor:deploy": "bash monitoring/deploy-monitoring.sh",
    "monitor:verify": "node monitoring/scripts/verify-monitoring.js",
    "monitor:summary": "node monitoring/scripts/generate-summary.js",
    "monitor:logs": "docker-compose -f monitoring/docker-compose.yml logs -f",
    "monitor:start": "docker-compose -f monitoring/docker-compose.yml up -d",
    "monitor:stop": "docker-compose -f monitoring/docker-compose.yml down",
    "monitor:restart": "docker-compose -f monitoring/docker-compose.yml restart",
    "monitor:status": "docker-compose -f monitoring/docker-compose.yml ps",
    "monitor:open-grafana": "open http://localhost:3000 2>/dev/null || xdg-open http://localhost:3000 2>/dev/null || echo 'Open http://localhost:3000 in browser'",
    "monitor:open-prometheus": "open http://localhost:9090 2>/dev/null || xdg-open http://localhost:9090 2>/dev/null || echo 'Open http://localhost:9090 in browser'",
    "perf:migrate": "node scripts/migrate-performance-optimization.js --apply",
    "perf:migrate:dry": "node scripts/migrate-performance-optimization.js --dry-run",
    "perf:check": "node scripts/migrate-performance-optimization.js --check",
    "perf:stats": "node scripts/performance-stats.js",
    "perf:benchmark": "node scripts/benchmark-performance.js",
    "perf:warm-cache": "node scripts/warm-cache.js",
    "launch:validate": "bash scripts/launch-revolution.sh validate",
    "launch:staging": "bash scripts/launch-revolution.sh staging",
    "launch:production": "bash scripts/launch-revolution.sh production",
    "launch:revolution": "bash scripts/launch-revolution.sh launch",
    "launch:rollback": "bash scripts/launch-revolution.sh rollback",
    "launch:monitor": "docker-compose -f monitoring/docker-compose.launch.yml up -d",
    "launch:monitor:stop": "docker-compose -f monitoring/docker-compose.launch.yml down",
    "launch:health": "node scripts/health-check.js",
    "launch:backup": "bash scripts/create-backup.sh",
    "launch:analytics": "node scripts/launch-analytics.js",
    "stripe:login": "stripe login",
    "stripe:listen": "stripe listen --forward-to http://localhost:3000/webhook",
    "stripe:trigger": "stripe trigger payment_intent.succeeded",
    "stripe:webhook": "stripe listen --forward-to http://localhost:3000/stripe/webhook",
    "mcp:stripe": "node .kilo/mcp/stripe-server.mjs",
    "lint:all": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.17.1",
    "@hookform/resolvers": "^5.2.2",
    "@mendable/firecrawl-js": "^4.21.0",
    "@neondatabase/serverless": "^1.1.0",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@sentry/browser": "^10.52.0",
    "@types/uuid": "^10.0.0",
    "canvas-confetti": "^1.9.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "csv-parse": "^6.2.1",
    "csv-stringify": "^6.7.0",
    "dompurify": "^3.3.3",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.45.2",
    "drizzle-zod": "^0.5.1",
    "framer-motion": "^11.18.2",
    "lucide-react": "^0.548.0",
    "openai": "^6.35.0",
    "react": "^18.3.1",
    "react-countup": "^6.5.3",
    "react-dom": "^18.3.1",
    "react-helmet-async": "^3.0.0",
    "react-hook-form": "^7.66.0",
    "react-intersection-observer": "^10.0.0",
    "react-responsive": "^10.0.1",
    "react-router-dom": "^6.22.0",
    "react-tilt": "^1.0.2",
    "react-type-animation": "^3.2.0",
    "react-typed": "^2.0.12",
    "react-use-measure": "^2.1.1",
    "reactflow": "^11.11.4",
    "swiper": "^12.0.3",
    "tailwind-merge": "^3.5.0",
    "uuid": "^14.0.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.1",
    "@headlessui/react": "^1.7.17",
    "@playwright/test": "^1.59.1",
    "@supabase/supabase-js": "^2.99.2",
    "@tailwindcss/forms": "^0.5.7",
    "@tailwindcss/typography": "^0.5.10",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/dompurify": "^3.0.5",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@types/react-lazy-load-image-component": "^1.6.3",
    "@vitejs/plugin-react": "^5.1.0",
    "@vitest/coverage-v8": "^4.1.0",
    "@vitest/ui": "^4.0.5",
    "autoprefixer": "^10.4.18",
    "eslint": "^9.9.1",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "globals": "^15.9.0",
    "jest-environment-jsdom": "^30.1.2",
    "jsdom": "^27.0.0",
    "postcss": "^8.4.35",
    "rollup-plugin-visualizer": "^7.0.1",
    "supabase": "^2.72.2",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.21.0",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.3.0",
    "vite": "^7.1.12",
    "vite-plugin-image-optimizer": "^2.0.2",
    "vitest": "^4.0.5"
  }
}
