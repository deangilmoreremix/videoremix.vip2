# Monitoring and Alerting Environment Variables
# Add these to your .env file

# ===================================================================
# SLACK INTEGRATION
# ===================================================================
# Get from Slack App: https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
SLACK_ALERT_CHANNEL=#monitoring-alerts
SLACK_COST_CHANNEL=#cost-alerts

# ===================================================================
# GRAFANA ACCESS
# ===================================================================
GRAFANA_ADMIN_PASSWORD=change_this_to_secure_password
# Optional: Set custom Grafana URL for links
GRAFANA_URL=http://localhost:3000

# ===================================================================
# PROMETHEUS CONFIGURATION
# ===================================================================
PROMETHEUS_RETENTION_DAYS=30
PROMETHEUS_STORAGE_PATH=/prometheus

# ===================================================================
# COST ALERTING
# ===================================================================
# Thresholds from migration-config.json
COST_ALERT_DAILY_THRESHOLD=50
COST_ALERT_MONTHLY_THRESHOLD=1000
COST_ALERT_PERCENTAGE=80
# Send warning at 80% of threshold (default: $40 daily, $800 monthly)

# ===================================================================
# ALERT SCHEDULING
# ===================================================================
ALERT_CHECK_INTERVAL=5  # minutes
DAILY_COST_REPORT_HOUR=9  # UTC
WEEKLY_REPORT_DAY=1  # Monday
WEEKLY_REPORT_HOUR=10  # UTC
MONTHLY_REPORT_DAY=1
MONTHLY_REPORT_HOUR=11  # UTC

# ===================================================================
# EMAIL NOTIFICATIONS (Optional)
# ===================================================================
# For email fallback when Slack is unavailable
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
ALERT_EMAIL_RECIPIENT=devops@videoremix.vip
ALERT_EMAIL_FROM=monitor@videoremix.vip

# ===================================================================
# MONITORING FEATURE FLAGS
# ===================================================================
ENABLE_COST_TRACKING=true
ENABLE_PERFORMANCE_MONITORING=true
ENABLE_ERROR_TRACKING=true
ENABLE_AUTOMATED_REPORTS=true
ENABLE_HEALTH_CHECKS=true
ENABLE_LOGGING_AGGREGATION=true

# ===================================================================
# EXTERNAL INTEGRATIONS
# ===================================================================
# Sentry for error tracking (optional)
SENTRY_DSN=https://your-sentry-dsn.ingest.sentry.io/project-id

# DataDog (alternative monitoring)
# DATADOG_API_KEY=your-api-key
# DATADOG_APP_KEY=your-app-key

# PagerDuty for critical alerts
# PAGERDUTY_INTEGRATION_KEY=your-integration-key

# ===================================================================
# OPENAI USAGE API
# ===================================================================
# Organization ID from OpenAI dashboard
OPENAI_ORG_ID=org-xxxxxxxxxxxxx

# ===================================================================
# DATABASE CONNECTIONS
# ===================================================================
# For metrics collection from app usage
POSTGRES_HOST=db.supabase.co
POSTGRES_PORT=5432
POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=${SUPABASE_SERVICE_ROLE_KEY}

# ===================================================================
# REDIS (if using for caching)
# ===================================================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ===================================================================
# STORAGE FOR ARCHIVES
# ===================================================================
# S3 for long-term log/metrics storage
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET_METRICS=videoremix-metrics-archive
S3_BUCKET_LOGS=videoremix-logs-archive

# ===================================================================
# NETWORK & ACCESS
# ===================================================================
# Comma-separated list of IPs allowed to scrape metrics
PROMETHEUS_ALLOWED_NETS=127.0.0.1/32,10.0.0.0/8
# Comma-separated list of IPs allowed to access Grafana
GRAFANA_ALLOWED_NETS=127.0.0.1/32,10.0.0.0/8

# ===================================================================
# ALERT COOLDOWNS
# ===================================================================
ALERT_COOLDOWN_MINUTES=15  # Minimum time between identical alerts
CRITICAL_ALERT_COOLDOWN_MINUTES=60
WARNING_ALERT_COOLDOWN_MINUTES=30

# ===================================================================
# REPORTING
# ===================================================================
REPORT_RECIPIENTS=team@videoremix.vip,stakeholders@videoremix.vip
DAILY_REPORT_ENABLED=true
WEEKLY_REPORT_ENABLED=true
MONTHLY_REPORT_ENABLED=true

# ===================================================================
# CUSTOM THRESHOLDS (for alerting)
# ===================================================================
RESPONSE_TIME_P95_THRESHOLD_MS=2000
ERROR_RATE_THRESHOLD_PERCENT=5
CPU_USAGE_THRESHOLD_PERCENT=80
MEMORY_USAGE_THRESHOLD_PERCENT=85
DISK_USAGE_THRESHOLD_PERCENT=90

# ===================================================================
# DASHBOARD CONFIGURATION
# ===================================================================
# Home dashboard to show on Grafana login
GRAFANA_HOME_DASHBOARD=openai-usage
GRAFANA_THEME=dark

# ===================================================================
# NOTIFICATION RULES
# ===================================================================
# Separate Slack channels by severity
CRITICAL_ALERT_CHANNEL=#monitoring-critical
WARNING_ALERT_CHANNEL=#monitoring-warnings
COST_ALERT_CHANNEL=#cost-alerts
ERROR_ALERT_CHANNEL=#error-tracker

# PagerDuty service keys
PAGERDUTY_CRITICAL_SERVICE_KEY=
PAGERDUTY_WARNING_SERVICE_KEY=

# ===================================================================
# ADVANCED SETTINGS
# ===================================================================
LOG_LEVEL=info  # debug, info, warn, error
METRICS_PORT=9464  # Default metrics exposition port
METRICS_PATH=/metrics
HEALTH_PATH=/health

# Opsgenie (optional)
# OPSGENIE_API_KEY=

# Microsoft Teams (optional)
# TEAMS_WEBHOOK_URL=

# Discord (optional)
# DISCORD_WEBHOOK_URL=

# ===================================================================
# COST ANOMALY DETECTION
# ===================================================================
COST_SPIKE_THRESHOLD=3.0  # Alert if current rate is 3x average
COST_ANOMALY_WINDOW_HOURS=24
COST_ANOMALY_LOOKBACK_DAYS=30
