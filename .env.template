# =============================================================================
# VIDEOREMIX ENVIRONMENT CONFIGURATION
# =============================================================================
# ⚠️  IMPORTANT: Copy this file to .env and fill in your actual values
# ⚠️  NEVER commit .env to version control!
# =============================================================================

# -----------------------------------------------------------------------------
# SUPABASE CONFIGURATION
# -----------------------------------------------------------------------------
# Get these from: https://supabase.com/dashboard → Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ⚠️  SECURITY: Service role key is for SERVER-SIDE ONLY!
# Never use this in frontend code. Configure in Netlify/Vercel environment.
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# -----------------------------------------------------------------------------
# SITE URL CONFIGURATION
# -----------------------------------------------------------------------------
VITE_SITE_URL=http://localhost:5173

# -----------------------------------------------------------------------------
# STRIPE CONFIGURATION
# -----------------------------------------------------------------------------
# Get publishable key from: https://dashboard.stripe.com/apikeys
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key

# ⚠️  SECURITY: Webhook secret is for SERVER-SIDE ONLY!
# STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# -----------------------------------------------------------------------------
# PAYPAL CONFIGURATION (Optional)
# -----------------------------------------------------------------------------
# PAYPAL_WEBHOOK_ID=your_paypal_webhook_id

# -----------------------------------------------------------------------------
# AI API KEYS (Optional - only if using AI features)
# -----------------------------------------------------------------------------
# Get from: https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-your_openai_key

# Get from: https://aistudio.google.com/app/apikeys
# GEMINI_API_KEY=your_gemini_api_key

# =============================================================================
# AFTER SETTING UP .env:
# 1. Run: git status
# 2. If .env was committed, rotate all exposed keys immediately!
# 3. Verify .env is in .gitignore
# =============================================================================
